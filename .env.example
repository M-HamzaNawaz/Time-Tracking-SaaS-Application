# PostgreSQL connection string used by Prisma (driver adapter + migrations)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tracking_app"

# Secret used to sign NextAuth JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Canonical URL of the app, used for callbacks and invite links
NEXTAUTH_URL="http://localhost:3000"

# Resend API key for sending invitation emails.
# Leave as-is to skip email sending (invite links are logged to the console instead).
RESEND_API_KEY="re_123456789"
